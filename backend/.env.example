PORT=3001
NODE_ENV=development

# LLM Configuration (use either GEMINI or OPENAI)
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# CORS origin
CORS_ORIGIN=http://localhost:3000

# Upload config
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# Batch config
BATCH_SIZE=10
MAX_RETRIES=3
RETRY_DELAY_MS=1000
